@model List<PAW3.Web.Models.ViewModels.ProductSummaryViewModel>

@{
    ViewData["Title"] = "Summary";
}

<div class="summary-card">
    <div class="summary-header">
        <h2><i class="fas fa-chart-bar text-primary-custom me-2"></i>Product Summary</h2>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Rating Class</th>
                    <th>Time Class</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var summary in Model)
                {
                    <tr>
                        <td>@summary.RatingClass</td>
                        <td>@summary.TimeClass</td>
                        <td>@summary.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle me-2"></i>No summary data available.
        </div>
    }
</div>